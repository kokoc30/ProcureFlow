      "Bash(.venv/Scripts/python.exe -c \"import fastapi; open\\(''_ver.txt'',''w''\\).write\\(fastapi.__version__\\)\")",
      "Bash(echo \"RC=$?\")",
      "Bash(.venv/Scripts/python.exe --version)",
      "Bash(.venv/Scripts/python.exe -c \"1+1\")",
      "Bash(echo \"exit=$?\")"
    ]
  }
}
